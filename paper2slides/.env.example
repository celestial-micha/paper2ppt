# Text LLM used for paper summarization, planning, deck curation, and optional figure analysis.
RAG_LLM_API_KEY=your_api_key_here
RAG_LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=gpt-4o-mini

# Optional: use a vision-capable text model to understand extracted paper figures.
PPTX_ENABLE_FIGURE_ANALYSIS=1
PPTX_VISION_MODEL=gpt-4o-mini
PPTX_MAX_FIGURE_ANALYSIS=5

# PPTX QA repair loop. Increase only if your decks are still too dense.
PPTX_QA_MAX_REPAIR_ATTEMPTS=2

